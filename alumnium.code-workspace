{
  "folders": [
    {
      "name": "ROOT",
      "path": ".",
    },
    {
      "name": "packages/python",
      "path": "packages/python",
    },
    {
      "name": "packages/typescript",
      "path": "packages/typescript",
    },
    {
      "name": "websites/docs",
      "path": "websites/docs",
    },
  ],
  "settings": {
    "cSpell.flagWords": ["Aluminium", "aluminium", "Aluminum", "aluminum"],
    "cSpell.words": ["alumnium", "Alumnium", "Ollama"],
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "files.exclude": {
      "packages/**": true,
      "websites/**": true,
    },
    "js/ts.experimental.useTsgo": true,
    "python.defaultInterpreterPath": "packages/python/.venv/bin/python",
    "search.exclude": {
      "**/dist": true,
      "**/node_modules": true,
    },
    "testing.automaticallyOpenPeekView": "never",
    "[javascript]": {
      "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit",
      },
    },
  },
}
