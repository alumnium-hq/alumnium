{
  "name": "@alumnium/system-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Temporary? package holding system tests for Alumnium",
  "keywords": [
    "ai",
    "alumnium",
    "appium",
    "automation",
    "playwright",
    "selenium",
    "webdriverio"
  ],
  "license": "MIT",
  "author": "Alex Rodionov <p0deje@gmail.com>",
  "contributors": [
    "Alex Rodionov <p0deje@gmail.com>",
    "Tatiana Shepeleva <tati.shep@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alumnium-hq/alumnium.git"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf .alumnium/cache log/ playwright-report/ test-results/",
    "examples:appium": "ALUMNIUM_DRIVER=appium wdio run wdio.conf.ts",
    "examples:playwright": "ALUMNIUM_DRIVER=playwright playwright test",
    "examples:selenium": "ALUMNIUM_DRIVER=selenium mocha",
    "examples": "bun run examples:appium && bun run examples:playwright && bun run examples:selenium",
    "types": "tsgo --noEmit",
    "types:watch": "tsgo --noEmit --watch"
  },
  "dependencies": {
    "@logtape/file": "^1.1.1",
    "@logtape/logtape": "^1.1.1",
    "alumnium": "workspace:*",
    "alwaysly": "^0.4.0",
    "playwright": "^1.55.1",
    "selenium-webdriver": "^4.17.0",
    "webdriverio": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.55.1",
    "@types/eslint__js": "^8.42.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/selenium-webdriver": "^4.1.21",
    "@wdio/cli": "^9.20.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "appium-xcuitest-driver": "^10.2.1",
    "eslint": "^9.37.0",
    "mocha": "^10.3.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "wdio-lambdatest-service": "^4.0.0"
  }
}
