{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "categories": {},
  "rules": {
    "restrict-template-expressions": "off", // Allow implicit string coercion in tempalate literals.
    // TODO: Create an issue in Oxlint or corresponding ESLint repo.
    "typescript/no-base-to-string": "off", // Useful but fails to detect branded types
    // TODO: Create an issue in Oxlint suggesting to add `exactOptionalPropertyTypes` support.
    "typescript/no-duplicate-type-constituents": "off", // Useful but fails on optional arguments with `| undefined`

    "no-restricted-imports": [
      "error",
      {
        "paths": [
          // Force "node:path" instead of "path"
          {
            "name": "path",
            "message": "Always use \"node:path\": `import path from \"node:path\"`"
          },
          // Disallow named imports from `node:path`
          {
            "name": "node:path",
            "allowImportNames": ["default"],
            "message": "Always use default import: `import path from \"node:path\"`"
          }
        ]
      }
    ]

    // TODO: Enabled when available in Oxlint, see: https://github.com/oxc-project/oxc/issues/479
    // "no-restricted-syntax": [
    //   "error",
    //   // Disallow default imports from `node:path` that aren't named `path`
    //   {
    //     "selector": "ImportDeclaration[source.value='node:path'] ImportDefaultSpecifier[local.name!='path']",
    //     "message": "Default import from 'node:path' must be named `path`"
    //   }
    // ]

    // TODO: Enabled when available in Oxlint, see: https://github.com/oxc-project/oxc/issues/479
    // "no-restricted-properties": [
    //   "error",
    //   // Disallow using `path.join`
    //   {
    //     "object": "path",
    //     "property": "join",
    //     "message": "Use `safePathJoin` instead of `path.join`"
    //   }
    // ]
  },
  "settings": {
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": false
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": []
}
