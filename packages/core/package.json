{
  "name": "alumnium",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "description": "Pave the way towards AI-powered test automation",
  "keywords": [
    "ai",
    "alumnium",
    "automation",
    "appium",
    "playwright",
    "selenium",
    "webdriverio"
  ],
  "author": "Alex Rodionov <p0deje@gmail.com>",
  "contributors": [
    "Alex Rodionov <p0deje@gmail.com>",
    "Tatiana Shepeleva <tati.shep@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alumnium-hq/alumnium.git"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./src/client/index.ts"
  },
  "overrides": {
    "exports": {
      ".": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "./scripts/build.ts",
    "clean": "node -e \"console.log('TODO')\"",
    "check-format": "node -e \"console.log('TODO')\"",
    "format": "node -e \"console.log('TODO')\"",
    "test": "bun test --preload ./tests/py2ts.ts",
    "test:watch": "bun test --preload ./tests/py2ts.ts --watch",
    "types": "tsc --noEmit",
    "types:watch": "tsc --noEmit --watch"
  },
  "devDependencies": {
    "@smithy/types": "^4.13.0",
    "@types/bun": "^1.3.9",
    "@types/selenium-webdriver": "^4.35.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@langchain/anthropic": "^1.3.20",
    "@langchain/aws": "^1.2.5",
    "@langchain/core": "^1.1.28",
    "@langchain/deepseek": "^1.0.14",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/mistralai": "^1.0.5",
    "@langchain/ollama": "^1.2.4",
    "@langchain/openai": "^1.2.10",
    "@langchain/xai": "^1.3.6",
    "@logtape/file": "^2.0.2",
    "@logtape/logtape": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.86",
    "alwaysly": "^0.4.0",
    "diff": "^8.0.3",
    "dom-serializer": "^2.0.0",
    "domhandler": "^5.0.3",
    "elysia": "^1.4.26",
    "htmlparser2": "^10.1.0",
    "playwright": "^1.58.2",
    "selenium-webdriver": "^4.41.0",
    "smollog": "^0.2.0",
    "webdriverio": "^9.24.0",
    "xml-formatter": "^3.6.7"
  }
