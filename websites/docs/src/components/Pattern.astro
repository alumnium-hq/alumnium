---
import Author from "./Author.astro";
import FormattedDate from "./FormattedDate.astro";
import Tags from "./Tags.astro";

interface Props {
  title: string;
  date: Date;
  mode?: "post" | "list";
  author: {
    name: string;
    image: string;
  };
  tags?: string[];
}

const { title, mode, date, author, tags } = Astro.props;

const h3Class = [
  "font-bold text-white leading-tight text-center text-balance text-3xl",
  mode === "post" ? "sm:text-[3rem]" : "sm:text-[2rem] md:text-[2.5rem]",
];
---

<div>
  <div
    class:list={[
      "pattern-canvas-content not-content overflow-hidden",
      mode === "post" ? "" : "sm:aspect-video rounded-xl",
    ]}
  >
    <div
      class:list={[
        "bg-linear-to-b from-canvas/0 to-content-dark/80 w-full h-full flex flex-col justify-end items-center px-2 py-4 sm:p-10",
        mode === "post" ? "pt-20 sm:pt-40" : "pt-20 sm:pt-4",
      ]}
    >
      <div class="gap-3 flex flex-col items-center max-w-5xl">
        {
          mode === "post" ? (
            <h1 class:list={h3Class} id="_top">
              {title}
            </h1>
          ) : (
            <h3 class:list={h3Class}>{title}</h3>
          )
        }

        <div class="text-gray-200">
          <Author prefix="Published by" author={author} />
        </div>

        <div class="text-gray-300">
          <FormattedDate date={date} />
        </div>

        <Tags tags={tags} mode="pattern" />
      </div>
    </div>
  </div>
</div>
