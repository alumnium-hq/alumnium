---
import { tt } from "#/copy";
import type { AstroComponentInstance } from "astro/runtime/server/index.js";
import Tabs from "../landings/blocks/Tabs.astro";
import Code from "./Code.astro";
import type { TtGetStarted } from "#/copy/getStarted";

const t = tt.getStarted;

type T = typeof t;

type TestExampleVariantKey = keyof T extends infer Key
  ? Key extends keyof T
    ? T[Key] extends TtGetStarted.TestExampleVariant
      ? Key
      : never
    : never
  : never;

type RenderContent = <Id extends TestExampleVariantKey>(
  id: Id,
) => AstroComponentInstance;
---

<Fragment>
  {
    () => {
      const renderContent: RenderContent = (id) => {
        const tContent = t[id];
        return (
          <>
            <Code code={tContent.code} lang={tContent.lang} />
          </>
        );
      };

      return (
        <Tabs
          items={[
            {
              id: "test-client-ts",
              label: t["test-client-ts"].tab,
              items: [
                {
                  id: "test-client-ts-selenium",
                  label: t["test-client-ts-selenium"].tab,
                },
                {
                  id: "test-client-ts-playwright",
                  label: t["test-client-ts-playwright"].tab,
                },
                {
                  id: "test-client-ts-appium",
                  label: t["test-client-ts-appium"].tab,
                },
              ],
            },
            {
              id: "test-client-python",
              label: t["test-client-python"].tab,
              items: [
                {
                  id: "test-client-python-selenium",
                  label: t["test-client-python-selenium"].tab,
                },
                {
                  id: "test-client-python-playwright",
                  label: t["test-client-python-playwright"].tab,
                },
                {
                  id: "test-client-python-appium",
                  label: t["test-client-python-appium"].tab,
                },
              ],
            },
            {
              id: "test-client-java",
              label: t["test-client-java"].tab,
              items: [
                {
                  id: "test-client-java-selenium",
                  label: t["test-client-java-selenium"].tab,
                },
                {
                  id: "test-client-java-playwright",
                  label: t["test-client-java-playwright"].tab,
                },
                {
                  id: "test-client-java-appium",
                  label: t["test-client-java-appium"].tab,
                },
              ],
            },
          ]}
          active="test-client-ts-selenium"
          style="code"
        >
          <Fragment slot="test-client-ts-selenium">
            {renderContent("test-client-ts-selenium")}
          </Fragment>

          <Fragment slot="test-client-ts-playwright">
            {renderContent("test-client-ts-playwright")}
          </Fragment>

          <Fragment slot="test-client-ts-appium">
            {renderContent("test-client-ts-appium")}
          </Fragment>

          <Fragment slot="test-client-python-selenium">
            {renderContent("test-client-python-selenium")}
          </Fragment>

          <Fragment slot="test-client-python-playwright">
            {renderContent("test-client-python-playwright")}
          </Fragment>

          <Fragment slot="test-client-python-appium">
            {renderContent("test-client-python-appium")}
          </Fragment>

          <Fragment slot="test-client-java-selenium">
            {renderContent("test-client-java-selenium")}
          </Fragment>

          <Fragment slot="test-client-java-playwright">
            {renderContent("test-client-java-playwright")}
          </Fragment>

          <Fragment slot="test-client-java-appium">
            {renderContent("test-client-java-appium")}
          </Fragment>
        </Tabs>
      );
    }
  }
</Fragment>
