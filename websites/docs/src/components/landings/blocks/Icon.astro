---
import type { ImageMetadata } from "astro";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { Image } from "astro:assets";

export interface Props {
  id: string;
  class?: string;
}

// NOTE: To avoid load compilation times, each used icon id must be listed
// inside `{...}.svg`.
// TODO: Test the performance after Astro upgrades to the Rolldown-powered
// Vite version.
const icons = import.meta.glob<{ default: ImageMetadata }>(
  "../../../../node_modules/@material-symbols/svg-300/rounded/{savings,avg_pace,graph_1}.svg",
);

const { id, class: className } = Astro.props;

const iconFilePath = `../../../../node_modules/@material-symbols/svg-300/rounded/${id}.svg`;
const iconPath = icons[iconFilePath];
if (!iconPath)
  throw new Error(`Icon ${id} has not been found at ${iconFilePath}`);

const IconFactory = await iconPath().then(
  (m) => m.default as unknown as AstroComponentFactory,
);
---

<IconFactory class={className} />
