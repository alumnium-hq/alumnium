---
import Crosses from "./Crosses.astro";
import {
  type Props as ContentProps,
  type SectionContentHeadingProp,
} from "./SectionContent.astro";
import SectionContent from "./SectionContent.astro";
import SectionExtra, { type SectionExtraProps } from "./SectionExtra.astro";

export interface BaseProps {
  cols?: 1 | 2;
  span?: 1 | 2 | 3 | 4 | 5 | 6;
  content?: SectionExtraProps & {
    heading?: SectionContentHeadingProp;
  };
  extra?: SectionExtraProps;
  style?: SectionStyle;
  align?: boolean;
  continue?: boolean;
}

export type SectionStyle = "default" | "header" | "compact";

export interface SectionContentfulProps extends BaseProps, ContentProps {}

export interface BareProps extends BaseProps {}

export type SectionProps = SectionContentfulProps | BareProps;

type Props = SectionProps;

const {
  cols,
  span,
  style,
  align,
  continue: continueProp,
  content: contentExtra,
  extra,
  ...contentProps
} = Astro.props;
---

<div
  class:list={[
    "relative",
    span === 2 && "col-span-2",
    span === 3 && "col-span-3",
    span === 4 && "col-span-4",
    span === 5 && "col-span-5",
    span === 6 && "col-span-6",
    continueProp && "has-continuation",
  ]}
>
  <div
    class:list={[
      "section",
      style === "header" && "section-header",
      style === "compact" && "section-compact",
      align && "section-align",
      (!cols || cols === 1) && "section-cols-1",
      cols === 2 && "section-cols-2",
    ]}
  >
    {
      "t" in contentProps && (
        <SectionContent {...contentProps}>
          {contentExtra ? (
            <SectionExtra {...contentExtra} />
          ) : (
            <slot name="content" />
          )}
        </SectionContent>
      )
    }

    {extra ? <SectionExtra {...extra} /> : <slot />}
  </div>

  <Crosses />
</div>
