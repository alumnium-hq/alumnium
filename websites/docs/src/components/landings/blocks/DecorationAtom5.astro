<decoration-atom-5 class="decoration-atom" aria-hidden="true">
  <canvas></canvas>
</decoration-atom-5>

<script>
  import { luma, type RenderPass } from "@luma.gl/core";
  import { Geometry, Model, SphereGeometry } from "@luma.gl/engine";
  import { webgl2Adapter } from "@luma.gl/webgl";
  import { Matrix4, Vector3 } from "@math.gl/core";

  type Mat4 = Matrix4;
  type Vec3 = [number, number, number];

  interface Particle {
    kind: "proton" | "neutron";
    position: Vec3;
  }

  interface Shell {
    electrons: number;
    duration: number;
    radius: number;
    rotateX: number;
    rotateZ: number;
  }

  interface ElectronMotion {
    phase: number;
    speed: number;
  }

  interface SphereUniforms extends Record<string, unknown> {
    baseColor: Vec3;
    lightDirection: Vec3;
    model: Mat4;
    modelViewProjection: Mat4;
  }

  interface OrbitUniforms extends Record<string, unknown> {
    lineColor: number[];
    modelViewProjection: Mat4;
  }

  const atom = {
    protons: 13,
    neutrons: 14,
    nucleusScale: 0.64,
    shells: [
      { electrons: 2, duration: 5, radius: 3.35, rotateX: 66, rotateZ: -18 },
      { electrons: 8, duration: 8, radius: 5.95, rotateX: 72, rotateZ: 54 },
      { electrons: 3, duration: 11, radius: 8.55, rotateX: 64, rotateZ: 132 },
    ] satisfies Shell[],
  };

  const nucleus = createNucleus(atom.protons, atom.neutrons);
  const shells = atom.shells;
  const shellElectronMotions = shells.map((shell, shellIndex) =>
    createElectronMotions(shellIndex, shell.electrons),
  );
  const maxShellRadius = Math.max(...shells.map((shell) => shell.radius));
  const sceneRadius = maxShellRadius + 0.55;
  const fieldOfView = deg(40);
  const modelParameters = {
    blend: true,
    blendColorOperation: "add",
    blendColorSrcFactor: "src-alpha",
    blendColorDstFactor: "one-minus-src-alpha",
    cullMode: "back",
    depthCompare: "less-equal",
    depthWriteEnabled: true,
  } as const;
  const orbitParameters = {
    ...modelParameters,
    cullMode: "none",
    depthWriteEnabled: false,
  } as const;

  class DecorationAtom5 extends HTMLElement {
    #connected = false;
    #frame = 0;
    #renderer?: Awaited<ReturnType<typeof createRenderer>>;
    #resizeObserver?: ResizeObserver;
    #reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    #start = performance.now();

    connectedCallback() {
      const canvas = this.querySelector("canvas");
      if (!canvas) return;

      this.#connected = true;
      this.style.setProperty("--atom-scene-radius", String(sceneRadius));
      this.#resizeObserver = new ResizeObserver(() => this.#renderer?.resize());
      this.#resizeObserver.observe(this);

      void createRenderer(canvas).then((renderer) => {
        if (!this.#connected) {
          renderer.dispose();
          return;
        }

        this.#renderer = renderer;
        this.#start = performance.now();
        this.#frame = requestAnimationFrame(this.#render);
      });
    }

    disconnectedCallback() {
      this.#connected = false;
      cancelAnimationFrame(this.#frame);
      this.#resizeObserver?.disconnect();
      this.#renderer?.dispose();
    }

    #render = (now: number) => {
      const time = this.#reduceMotion.matches ? 0 : (now - this.#start) / 1000;
      this.#renderer?.render(time, this);
      if (this.#reduceMotion.matches) return;
      this.#frame = requestAnimationFrame(this.#render);
    };
  }

  async function createRenderer(canvas: HTMLCanvasElement) {
    const device = await luma.createDevice({
      adapters: [webgl2Adapter],
      createCanvasContext: { canvas },
      type: "webgl",
      webgl: {
        alpha: true,
        antialias: true,
        depth: true,
        preserveDrawingBuffer: false,
        stencil: false,
      },
    });
    const light = normalizeVec3([0.35, 0.72, 0.58]);
    const sphereUniforms: SphereUniforms = {
      baseColor: [1, 1, 1],
      lightDirection: light,
      model: identity(),
      modelViewProjection: identity(),
    };
    const sphere = new Model(device, {
      fs: sphereFragmentShader,
      geometry: new SphereGeometry({ nlat: 10, nlong: 14 }),
      parameters: modelParameters,
      uniforms: sphereUniforms,
      vs: sphereVertexShader,
    });
    const orbits = shells.map((shell) => {
      const uniforms: OrbitUniforms = {
        lineColor: [1, 1, 1, 0.52],
        modelViewProjection: identity(),
      };

      return {
        model: new Model(device, {
          fs: orbitFragmentShader,
          geometry: createOrbitGeometry(shell.radius),
          parameters: orbitParameters,
          uniforms,
          vs: orbitVertexShader,
        }),
        uniforms,
      };
    });

    function resize() {
      const rect = canvas.getBoundingClientRect();
      const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);
      const width = Math.max(1, Math.round(rect.width * pixelRatio));
      const height = Math.max(1, Math.round(rect.height * pixelRatio));
      if (canvas.width === width && canvas.height === height) return;
      canvas.width = width;
      canvas.height = height;
    }

    resize();

    return {
      dispose() {
        sphere.destroy();
        orbits.forEach((orbit) => orbit.model.destroy());
        device.destroy();
      },
      render(time: number, host: HTMLElement) {
        resize();

        const width = canvas.width;
        const height = canvas.height;
        const aspect = width / Math.max(height, 1);
        const cameraDistance = sceneRadius / Math.tan(fieldOfView / 2) * 1.18;
        const projection = new Matrix4().perspective({
          aspect,
          far: cameraDistance + sceneRadius * 2,
          fovy: fieldOfView,
          near: 0.1,
        });
        const view = new Matrix4().lookAt({
          center: [0, 0, 0],
          eye: [0, 0, cameraDistance],
          up: [0, 1, 0],
        });
        const viewProjection = multiplyMat4(projection, view);
        const proton = cssColor(host, "--atom-color-proton", [0.52, 0.78, 1]);
        const neutron = cssColor(
          host,
          "--atom-color-neutron",
          [0.33, 0.43, 0.58],
        );
        const electron = cssColor(
          host,
          "--atom-color-electron",
          [0.92, 0.98, 1],
        );
        const orbitColor = cssColor(host, "--atom-color-orbit", [0.36, 0.56, 0.82]);
        const nucleusSpin = multiplyMat4(
          rotateY(time * 0.42),
          multiplyMat4(rotateX(deg(-16) + time * 0.19), rotateZ(time * 0.13)),
        );
        const renderPass = device.beginRenderPass({
          clearColor: [0, 0, 0, 0],
          clearDepth: 1,
          parameters: {
            viewport: [0, 0, width, height],
          },
        });

        for (const [shellIndex, shell] of shells.entries()) {
          const { model, uniforms } = orbits[shellIndex];
          uniforms.modelViewProjection = multiplyMat4(viewProjection, shellTransform(shell));
          uniforms.lineColor = [...orbitColor, 0.52];
          model.draw(renderPass);
        }

        for (const [index, particle] of nucleus.entries()) {
          const color = particle.kind === "proton" ? proton : neutron;
          const position = scaleVec3(particle.position, atom.nucleusScale);
          const model = multiplyMat4(
            nucleusSpin,
            multiplyMat4(
              translate(position),
              multiplyMat4(
                rotateY(time * (1.8 + (index % 4) * 0.25)),
                scale([0.27, 0.27, 0.27]),
              ),
            ),
          );
          drawSphere(renderPass, sphere, sphereUniforms, viewProjection, model, color, light);
        }

        for (const [shellIndex, shell] of shells.entries()) {
          for (
            let electronIndex = 0;
            electronIndex < shell.electrons;
            electronIndex++
          ) {
            const direction = shellIndex === 1 ? -1 : 1;
            const motion = shellElectronMotions[shellIndex][electronIndex];
            const angle =
              direction *
                (time / shell.duration) *
                motion.speed *
                Math.PI *
                2 +
              motion.phase;
            const position = transformVec3(shellTransform(shell, shell.radius), [
              Math.cos(angle),
              Math.sin(angle),
              0,
            ]);
            const model = multiplyMat4(
              translate(position),
              scale([0.18, 0.18, 0.18]),
            );
            drawSphere(renderPass, sphere, sphereUniforms, viewProjection, model, electron, light);
          }
        }

        renderPass.end();
        device.submit();
      },
      resize,
    };
  }

  function drawSphere(
    renderPass: RenderPass,
    model: Model,
    uniforms: SphereUniforms,
    viewProjection: Mat4,
    matrix: Mat4,
    color: Vec3,
    light: Vec3,
  ) {
    uniforms.baseColor = color;
    uniforms.lightDirection = light;
    uniforms.model = matrix;
    uniforms.modelViewProjection = multiplyMat4(viewProjection, matrix);
    model.draw(renderPass);
  }

  function createOrbitGeometry(radius: number) {
    const vertices: number[] = [];
    const indices: number[] = [];
    const segments = 160;
    const sides = 6;
    const thickness = 0.028;

    for (let segment = 0; segment <= segments; segment++) {
      const angle = (segment / segments) * Math.PI * 2;
      const center: Vec3 = [Math.cos(angle) * radius, Math.sin(angle) * radius, 0];
      const radial: Vec3 = [Math.cos(angle), Math.sin(angle), 0];
      for (let side = 0; side < sides; side++) {
        const sideAngle = (side / sides) * Math.PI * 2;
        vertices.push(
          center[0] + radial[0] * Math.cos(sideAngle) * thickness,
          center[1] + radial[1] * Math.cos(sideAngle) * thickness,
          Math.sin(sideAngle) * thickness,
        );
      }
    }

    for (let segment = 0; segment < segments; segment++) {
      const current = segment * sides;
      const next = (segment + 1) * sides;
      for (let side = 0; side < sides; side++) {
        const sideNext = (side + 1) % sides;
        indices.push(
          current + side,
          next + side,
          current + sideNext,
          next + side,
          next + sideNext,
          current + sideNext,
        );
      }
    }

    return new Geometry({
      attributes: {
        POSITION: { size: 3, value: new Float32Array(vertices) },
      },
      indices: { size: 1, value: new Uint16Array(indices) },
      topology: "triangle-list",
    });
  }

  function shellTransform(shell: Shell, radius = 1) {
    return multiplyMat4(
      rotateZ(deg(shell.rotateZ)),
      multiplyMat4(rotateX(deg(shell.rotateX)), scale([radius, radius, radius])),
    );
  }

  function createNucleus(protons: number, neutrons: number): Particle[] {
    const total = protons + neutrons;
    const kinds = createParticleKinds(protons, neutrons);

    return Array.from({ length: total }, (_, index) => {
      const point = fibonacciSpherePoint(index, total);
      const layerScale = 0.78 + (index % 5) * 0.08;
      const jitter = deterministicJitter(index, 0.11);

      return {
        kind: kinds[index],
        position: [
          point[0] * layerScale + jitter[0],
          point[1] * layerScale + jitter[1],
          point[2] * layerScale + jitter[2],
        ],
      };
    });
  }

  function createParticleKinds(protons: number, neutrons: number) {
    let protonCount = 0;
    let neutronCount = 0;

    return Array.from({ length: protons + neutrons }, (): Particle["kind"] => {
      const protonRatio = protonCount / protons;
      const neutronRatio = neutronCount / neutrons;

      if (
        protonCount < protons &&
        (neutronCount >= neutrons || protonRatio <= neutronRatio)
      ) {
        protonCount++;
        return "proton";
      }

      neutronCount++;
      return "neutron";
    });
  }

  function createElectronMotions(shellIndex: number, electrons: number): ElectronMotion[] {
    return Array.from({ length: electrons }, (_, electronIndex) => {
      const spacing = (Math.PI * 2) / electrons;
      const basePhase = electronIndex * spacing;
      const phaseJitter =
        (seededUnit(shellIndex * 31 + electronIndex, 4) - 0.5) * spacing * 0.54;
      const speed = 0.86 + seededUnit(shellIndex * 31 + electronIndex, 5) * 0.28;

      return {
        phase: basePhase + phaseJitter,
        speed,
      };
    });
  }

  function fibonacciSpherePoint(index: number, total: number): Vec3 {
    const offset = 2 / total;
    const increment = Math.PI * (3 - Math.sqrt(5));
    const y = index * offset - 1 + offset / 2;
    const radius = Math.sqrt(1 - y * y);
    const angle = index * increment;

    return [Math.cos(angle) * radius, y, Math.sin(angle) * radius];
  }

  function deterministicJitter(index: number, amount: number): Vec3 {
    return [
      (seededUnit(index, 1) - 0.5) * amount,
      (seededUnit(index, 2) - 0.5) * amount,
      (seededUnit(index, 3) - 0.5) * amount,
    ];
  }

  function seededUnit(index: number, salt: number) {
    const value = Math.sin(index * 12.9898 + salt * 78.233) * 43758.5453;
    return value - Math.floor(value);
  }

  function cssColor(host: HTMLElement, name: string, fallback: Vec3): Vec3 {
    const raw = getComputedStyle(host).getPropertyValue(name).trim();
    if (!raw) return fallback;

    const canvas = document.createElement("canvas");
    const context = canvas.getContext("2d");
    if (!context) return fallback;

    context.fillStyle = raw;
    const parsed = context.fillStyle;
    const rgb = parsed.match(/rgba?\((\d+), (\d+), (\d+)/);
    if (rgb)
      return [Number(rgb[1]) / 255, Number(rgb[2]) / 255, Number(rgb[3]) / 255];

    const hex = parsed.match(/^#([0-9a-f]{6})$/i);
    if (!hex) return fallback;
    return [
      Number.parseInt(hex[1].slice(0, 2), 16) / 255,
      Number.parseInt(hex[1].slice(2, 4), 16) / 255,
      Number.parseInt(hex[1].slice(4, 6), 16) / 255,
    ];
  }

  function translate(point: Vec3): Mat4 {
    return new Matrix4().translate(point);
  }

  function scale(point: Vec3): Mat4 {
    return new Matrix4().scale(point);
  }

  function rotateX(angle: number): Mat4 {
    return new Matrix4().rotateX(angle);
  }

  function rotateY(angle: number): Mat4 {
    return new Matrix4().rotateY(angle);
  }

  function rotateZ(angle: number): Mat4 {
    return new Matrix4().rotateZ(angle);
  }

  function multiplyMat4(a: Mat4, b: Mat4): Mat4 {
    return new Matrix4(a).multiplyRight(b);
  }

  function scaleVec3(point: Vec3, amount: number): Vec3 {
    const output = new Vector3(point).scale(amount);
    return [output.x, output.y, output.z];
  }

  function transformVec3(matrix: Mat4, point: Vec3): Vec3 {
    const output = matrix.transformAsPoint(point, []);
    return [output[0], output[1], output[2]];
  }

  function normalizeVec3(point: Vec3): Vec3 {
    const output = new Vector3(point).normalize();
    return [output.x, output.y, output.z];
  }

  function identity(): Mat4 {
    return new Matrix4();
  }

  function deg(value: number) {
    return (value * Math.PI) / 180;
  }

  const sphereVertexShader = `#version 300 es
    in vec3 positions;
    in vec3 normals;
    uniform mat4 model;
    uniform mat4 modelViewProjection;
    out vec3 vNormal;
    void main() {
      vNormal = normalize((model * vec4(normals, 0.0)).xyz);
      gl_Position = modelViewProjection * vec4(positions, 1.0);
    }
  `;

  const sphereFragmentShader = `#version 300 es
    precision mediump float;
    uniform vec3 baseColor;
    uniform vec3 lightDirection;
    in vec3 vNormal;
    out vec4 fragColor;
    void main() {
      float light = max(dot(normalize(vNormal), normalize(lightDirection)), 0.0);
      float rim = pow(1.0 - abs(vNormal.z), 2.0);
      vec3 color = baseColor * (0.34 + light * 0.86) + vec3(0.9, 0.96, 1.0) * rim * 0.22;
      fragColor = vec4(color, 1.0);
    }
  `;

  const orbitVertexShader = `#version 300 es
    in vec3 positions;
    uniform mat4 modelViewProjection;
    void main() {
      gl_Position = modelViewProjection * vec4(positions, 1.0);
    }
  `;

  const orbitFragmentShader = `#version 300 es
    precision mediump float;
    uniform vec4 lineColor;
    out vec4 fragColor;
    void main() {
      fragColor = lineColor;
    }
  `;

  if (!customElements.get("decoration-atom-5")) {
    customElements.define("decoration-atom-5", DecorationAtom5);
  }
</script>

<style>
  @reference "#/styles/global.css";

  .decoration-atom {
    @apply pointer-events-none select-none;
    --atom-color-proton: var(--color-accent-300);
    --atom-color-neutron: var(--color-accent-500);
    --atom-color-electron: var(--color-accent-100);
    --atom-color-orbit: var(--color-accent-400);
    --atom-scene-radius: 9.1;
    display: block;
    position: relative;
    width: calc(var(--atom-scene-radius) * 3.5em);
    height: calc(var(--atom-scene-radius) * 3.5em);
    contain: layout paint;
  }

  canvas {
    @apply absolute inset-0 size-full;
  }

  @media (prefers-reduced-motion: reduce) {
    canvas {
      opacity: 0.75;
    }
  }
</style>
