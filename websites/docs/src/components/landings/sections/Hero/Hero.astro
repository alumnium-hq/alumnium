---
import { tt } from "#/copy";
import Logotype from "#/assets/logotype.svg";
import { Icon } from "@astrojs/starlight/components";
import Banner from "./Banner.astro";
import Install from "#/components/blocks/Install.astro";

const t = tt.landings.sections.hero.en;

const stars = 818;
---

<div>
  <div class="content-inner-md flex flex-col items-center gap-16">
    <Banner />

    <div class="flex flex-col gap-5 items-center">
      <Logotype class="h-10" />

      <div class="heading text-center max-w-2xl">
        <h1 set:html={tt.md(t.headline)} class="h1 text-4xl font-medium" />

        <p class="subheadline">{t.subheadline}</p>
      </div>

      <!-- <Install /> -->

      <div class="w-xl border border-accent-600 h-[22rem]">TODO: Big demo</div>

      <div class="flex gap-3 items-center hidden">
        <a
          href="#"
          class="bg-logo px-6 py-2 rounded-sm text-white font-medium text-md no-underline"
          >{t.ctaGetStarted}</a
        >
        <a
          href="#"
          class="px-6 py-2 rounded-sm text-accent-400 border-accent-600 border font-medium text-md no-underline"
          >{t.ctaDiscord}</a
        >
      </div>

      <div class="inline-flex items-center gap-3 text-sm">
        <a
          href="https://github.com/alumnhium-hq/alumnium"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent-400 inline-flex items-center gap-2 no-underline"
        >
          <Icon name="github" class="inline-block h-6" />
          <span>{t.openSource}</span>
          <span
            class="no-underline text-xs border-gray-600 border p-0.5 font-medium rounded-sm inline-flex items-center gap-0.5"
          >
            <Icon name="star" class="h-3" />
            <span class="leading-0 capsize">{stars}</span>
          </span>
        </a>

        <span class="text-accent-500 font-bold">·</span>

        <span class="text-accent-400">{t.license}</span>

        <span class="text-accent-500 font-bold">·</span>
        <a
          href="https://github.com/alumnhium-hq/alumnium"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent-400 inline-flex items-center gap-2 no-underline"
        >
          <Icon name="discord" class="inline-block h-6" />
          <span>{t.community}</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  @reference "#/styles/global.css";

  .h1 {
    & :global(b) {
      @apply text-5xl font-medium;
    }

    & :global(a) {
      @apply text-accent-300;
    }
  }
</style>
