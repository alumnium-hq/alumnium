---
import { tt } from "#/copy";
import Step from "./Step.astro";
import InstallCli from "#/components/blocks/InstallCli.astro";
import InstallClient from "#/components/blocks/InstallClient.astro";

const t = tt.landings.sections.howSteps.install;
---

<Step t={t}>
  <Fragment slot="agents">
    <InstallCli />
  </Fragment>

  <Fragment slot="engineers">
    <InstallClient />
  </Fragment>
</Step>
