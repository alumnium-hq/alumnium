{
  "version": "2.0.0",
  "tasks": [
    //#region docs

    // root#dev
    {
      "type": "shell",
      "label": "docs#dev",
      "command": "mise",
      "args": ["//websites/docs:dev"],
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(.*)\\((\\d+,\\d+)\\):\\s+(error|warning|info)\\s+TS(\\d+):\\s+(.*)$",
            "file": 1,
            "location": 2,
            "severity": 3,
            "code": 4,
            "message": 5
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*ready in.*",
          "endsPattern": ".*ready in.*"
        }
      }
    }

    //#endregion
  ]
}
